{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "1.4",
  "description": "Sends your Claude usage data to the local tracker app.",
  "permissions": ["cookies", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon.png"
  }
}
